{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyMaxRetries": 5,
    "restartPolicyMaxBackoffSec": 300
  },
  "healthchecks": {
    "enabled": true,
    "endpoint": "/health"
  },
  "logs": {
    "enabled": true
  }
}
